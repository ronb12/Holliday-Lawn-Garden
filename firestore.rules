rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    // Checks the caller is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks the caller has role == 'admin' in their users doc
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Checks the caller owns the document via a userId field
    function isOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Checks incoming write sets userId to the caller's uid
    function isCreatingOwn() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ── Admin-only collections ────────────────────────────────────
    // These hold business data that only admins should access.

    match /appointments/{document} {
      allow read, write: if isAdmin();
    }

    match /customers/{document} {
      allow read, write: if isAdmin();
    }

    match /staff/{document} {
      allow read, write: if isAdmin();
    }

    match /contractors/{document} {
      allow read, write: if isAdmin();
    }

    match /contractor_projects/{document} {
      allow read, write: if isAdmin();
    }

    match /equipment/{document} {
      allow read, write: if isAdmin();
    }

    match /supplies/{document} {
      allow read, write: if isAdmin();
    }

    match /maintenance/{document} {
      allow read, write: if isAdmin();
    }

    match /messages/{document} {
      allow read, write: if isAdmin();
    }

    match /bulkMessages/{document} {
      allow read, write: if isAdmin();
    }

    match /notifications/{document} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── Schedule (admin writes; any logged-in user reads own) ─────
    match /schedule/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    match /scheduledServices/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    // ── Payments / invoices / billing ─────────────────────────────
    // Admins have full access; customers can only read their own records.

    match /payments/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    match /invoices/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    match /billing/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    // ── Services (customers can see their own history) ────────────
    match /services/{document} {
      allow read: if isAdmin() || isOwner();
      allow write: if isAdmin();
    }

    // ── Service requests (customers can create + view their own) ──
    match /serviceRequests/{document} {
      allow create: if isCreatingOwn();
      allow read:   if isAdmin() || isOwner();
      allow update, delete: if isAdmin();
    }

    // ── Real-time chat / typing indicators ───────────────────────
    match /chats/{document} {
      allow read, write: if isAuthenticated();
    }

    match /typing/{document} {
      allow read, write: if isAuthenticated();
    }

    // ── User profiles ─────────────────────────────────────────────
    // Each user can read/write only their own document.
    // Admins can read any user document.
    match /users/{userId} {
      allow read:  if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // ── Deny everything else by default ──────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
