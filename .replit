modules = ["web", "nodejs-20", "python-3.12", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sync to GitHub"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GitHub Auto-Sync"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Sync to GitHub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash github-sync.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "GitHub Auto-Sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash github-sync-daemon.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
